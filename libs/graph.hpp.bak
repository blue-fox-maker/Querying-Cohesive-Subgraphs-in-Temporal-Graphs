#include "config.hpp"
#include <algorithm>
#include <functional>
#include <limits>
#include <map>
#include <numeric>
#include <optional>
#include <ranges>

// graph descriptor

template <typename VId, typename VA = void>
struct vert_descriptor
{
    using vid = VId;
    VId id;
    VA attr;
};
template <typename VId>
struct vert_descriptor<VId, void>
{
    VId id;
};

template <typename VId, typename EA = void>
struct edge_descriptor
{
    VId source_id;
    VId target_id;
    EA attr;
};

template <typename VId>
struct edge_descriptor<VId, void>
{
    VId source_id;
    VId target_id;
};

template <typename VId, typename EA = void>
struct neighbor_descriptor
{
    using vid = VId;
    VId target_id;
    EA attr;
};

template <typename VId>
struct neighbor_descriptor<VId, void>
{
    using vid = VId;
    VId target_id;
};

template <typename VId, typename EA>
auto operator <=>(const neighbor_descriptor<VId,EA>&lhs,const neighbor_descriptor<VId,EA>&rhs){
    return lhs.target_id<=>rhs.target_id;
}


template <typename T>
concept Adj_Graph = true;

template <typename G>
struct graph_traits;
template <Adj_Graph G>
struct graph_traits<G>
{
    using vid = std::ranges::range_value_t<std::ranges::range_value_t<G>>::vid;
};

// basic function to define a graph

template <typename G>
size_t num_vert(G &&g);
template <Adj_Graph G>
size_t num_vert(G &&g)
{
    return std::ranges::size(g);
}

template <typename G>
auto verts(G&&g);
template <Adj_Graph G>
auto verts(G&&g){
    using vid = typename graph_traits<G>::vid;
    return std::views::iota(static_cast<vid>(0), static_cast<vid>(num_vert(g)));
}

template <typename G>
auto neighbors(G &&g, typename graph_traits<G>::vid v);
template <Adj_Graph G>
auto neighbors(G &&g, typename graph_traits<G>::vid v)
{
    return g[v];
}
template <typename G>
auto neighbor_verts(G&& g, typename graph_traits<G>::vid v){
    return neighbors(g,v)|std::views::transform([](auto&& x){return x.target_id;});
}

template <typename G>
size_t degree(G &&g, typename graph_traits<G>::vid v);
template <Adj_Graph G>
size_t degree(G &&g, typename graph_traits<G>::vid v){
    return std::ranges::size(neighbors(g,v));
}

// algorithms

template <typename G>
std::vector<size_t> k_core(G &&g, size_t k=-1)
{
    using vid = graph_traits<G>::vid;
    size_t n = num_vert(g);
    auto deg = std::vector<size_t>(n);
    auto vtx = std::vector<vid>(n);
    auto pos = std::vector<vid>(n);
    for (auto &&v : verts(g))
    {
        deg[v] = degree(g, v);
    }
    size_t max_deg = std::ranges::max(deg);
    auto bin = std::vector<size_t>(max_deg + 2);
    for (auto &&d : deg)
    {
        bin[d + 1]++;
    }
    bin.back() = 0;
    std::partial_sum(bin.begin(), bin.end(), bin.begin());
    for (auto &&v : verts(g))
    {
        pos[v] = bin[deg[v]];
        vtx[pos[v]] = v;
        bin[deg[v]]++;
    }
    std::rotate(bin.rbegin(), bin.rbegin() + 1, bin.rend());
    for (size_t i = 0; i < n; i++)
    {
        auto v = vtx[i];
        if(deg[v]>=k) break;
        for (auto &&u : neighbor_verts(g, v))
        {
            if (deg[u] > deg[v])
            {
                auto du = deg[u];
                auto pu = pos[u];
                auto pw = bin[du];
                auto w = vtx[pw];
                if (u != w)
                {
                    pos[u] = pw;
                    vtx[pu] = w;
                    pos[w] = pu;
                    vtx[pw] = u;
                }
                bin[du]++;
                deg[u]--;
            }
        }
    }
    deg.pop_back();
    return deg;
}

template <typename VId, typename EA, typename WProj = std::identity>
class minimum_spanning_forest
{
    public:
    using vert_t = vert_descriptor<VId>;
    using edge_t = edge_descriptor<VId, EA>;
    using size_type = size_t;

    minimum_spanning_forest(WProj proj) : _proj(proj) {}

    auto edges() const
    {
        return std::views::iota(0U, subsets.size()) | std::views::transform([&](const auto i) {
                   return edge_descriptor<VId, EA>{.source_id = i, .target_id = subsets[i].parent, .attr = subsets[i].attr};
               });
    }

    VId find(VId v)
    {
        if (auto p = subsets[v].parent; p != v)
        {
            auto res = find(p);
            subsets[v].depth = subsets[p].depth + 1;
            return res;
        }
        subsets[v].depth = 0;
        return v;
    }

    std::optional<edge_t> critical_edge(VId u, VId v)
    {
        if (find(u) != find(v))
            return {};
        std::optional<VId> cur;
        while (u != v)
        {
            if (subsets[u].depth < subsets[v].depth)
                std::swap(u, v);
            if (!cur || _proj(subsets[*cur].attr) < _proj(subsets[u].attr))
                cur = u;
            u = subsets[u].parent;
        }
        if (cur)
            return edge_t{.source_id = *cur, .target_id = subsets[*cur].parent, .attr = subsets[*cur].attr};
        else
            return std::nullopt;
    }

    VId reroot(VId u)
    {
        auto p = subsets[u].parent;
        if (p == u)
            return u;
        auto v = reroot(p);
        subsets[v].parent = u;
        subsets[v].attr = subsets[u].attr;
        return u;
    }

    std::optional<edge_t> add_edge(VId u, VId v, EA attr)
    {
        add_vert(u);
        add_vert(v);
        if (u == v)
            return {};
        auto e = critical_edge(u, v);
        if (subsets[u].depth > subsets[v].depth)
            std::swap(u, v);
        if (e)
        {
            if (_proj(e->attr) <= _proj(attr))
                return {};
            subsets[e->source_id].parent = e->source_id;
        }
        reroot(u);
        subsets[u].parent = v;
        subsets[u].attr = attr;
        return e;
    }
    std::optional<edge_t> try_add_edge(VId u, VId v, EA attr, bool& out_success)
    {
        add_vert(u);
        add_vert(v);
        if (u == v)
            return {};
        auto e = critical_edge(u, v);
        if (subsets[u].depth > subsets[v].depth)
            std::swap(u, v);
        if (e)
        {
            if (_proj(e->attr) <= _proj(attr))
                return {};
            subsets[e->source_id].parent = e->source_id;
        }
        out_success = true;
        reroot(u);
        subsets[u].parent = v;
        subsets[u].attr = attr;
        return e;
    }
    void add_vert(VId u)
    {
        auto cur = subsets.size();
        if (u >= subsets.size())
        {
            subsets.resize(u + 1);
            for (auto i = cur; i < subsets.size(); i++)
            {
                subsets[i].parent = i;
            }
        }
    }

    private:
    struct path
    {
        VId parent;
        EA attr;
        size_type depth;
    };

    WProj _proj;
    std::vector<path> subsets;
};

template <typename VId>
class DSU
{
    public:
    size_type size() const
    {
        return subsets.size();
    }
    auto edges() const
    {
        return std::views::iota(0, subsets.size()) | std::views::transform([&](const auto i) {
                   return edge_descriptor<VId>{.source_id = i, .target_id = subsets[i].parent};
               });
    }
    VId find(VId u)
    {
        return u == subsets[u].parent ? u : find(subsets[u].parent);
    }
    void add_edge(VId u, VId v)
    {
        add_vert(u);
        add_vert(v);
        u = find(u);
        v = find(v);
        if (u == v)
            return;
        if (subsets[u].size > subsets[v].size)
            std::swap(u, v);
        subsets[u].parent = v;
        subsets[v].size += subsets[u].size;
    }
    void add_vert(VId u)
    {
        auto cur = subsets.size();
        if (u >= subsets.size())
        {
            subsets.resize(u + 1);
            for (auto i = cur; i < subsets.size(); i++)
            {
                subsets[i].parent = i;
                subsets[i].size = 1;
            }
        }
    }

    private:
    struct path
    {
        VId parent;
        size_type size;
    };
    std::vector<path> subsets;
};

template <typename VId, typename EA, typename Proj>
auto TSF_index(std::vector<edge_descriptor<VId, EA>> edges, Proj &&proj)
{
    // note the type is fixed here
    std::map<std::array<int, 3>, std::vector<edge_descriptor<VId>>> res;
    std::ranges::sort(edges, {}, [&](const auto &e) {
        auto [ts, te] = proj(e.attr);
        return std::pair{te, -ts};
    });
    auto weight_proj = [&](const EA &attr) {
        auto [ts, te] = proj(attr);
        return std::pair{-ts, te};
    };
    auto msf = minimum_spanning_forest<VId, EA, decltype(weight_proj)>{weight_proj};
    for (auto &&e : edges)
    {
        if (e.source_id == e.target_id)
            continue;
        auto cur = msf.add_edge(e.source_id, e.target_id, e.attr);
        if (cur)
        {
            auto [t1, t2] = proj(cur->attr);
            auto [ts, te] = proj(e.attr);
            res[{t1, t2, te - 1}].emplace_back(cur->source_id, cur->target_id);
        }
    }
    for (auto &&e : msf.edges())
    {
        if(e.source_id!=e.target_id){
            auto [t1, t2] = proj(e.attr);
            res[{t1, t2, std::numeric_limits<decltype(t1)>::max()}].emplace_back(e.source_id, e.target_id);
        }
    }
    return res;
}
template <typename VId, typename EA, typename Proj>
auto TSF_index_for_update(std::vector<edge_descriptor<VId, EA>> edges, Proj &&proj)
{
    // note the type is fixed here
    std::map<std::array<int, 3>, std::vector<edge_descriptor<VId>>> res;
    std::ranges::sort(edges, {}, [&](const auto &e) {
        auto [ts, te] = proj(e.attr);
        return std::pair{te, -ts};
    });
    auto weight_proj = [&](const EA &attr) {
        auto [ts, te] = proj(attr);
        return std::pair{-ts, te};
    };
    auto msf = minimum_spanning_forest<VId, EA, decltype(weight_proj)>{weight_proj};
    for (auto &&e : edges)
    {
        if (e.source_id == e.target_id)
            continue;
        auto cur = msf.add_edge(e.source_id, e.target_id, e.attr);
        if (cur)
        {
            auto [t1, t2] = proj(cur->attr);
            auto [ts, te] = proj(e.attr);
            res[{t1, t2, te - 1}].emplace_back(cur->source_id, cur->target_id);
        }
    }
    for (auto &&e : msf.edges())
    {
        if(e.source_id!=e.target_id){
            auto [t1, t2] = proj(e.attr);
            res[{t1, t2, std::numeric_limits<decltype(t1)>::max()}].emplace_back(e.source_id, e.target_id);
        }
    }
    return std::pair{res,msf};
}
template <typename VId, typename EA, typename Proj>
auto TSF_index_update(auto& msf,edge_descriptor<VId, EA> edge, Proj &&proj)->std::pair<bool,std::optional<std::pair<int,int>>>
{
    auto [ts, te] = proj(edge.attr);
    auto weight = std::pair{-ts,te};
    if (edge.source_id == edge.target_id)
        return std::pair{false,std::nullopt};
    auto success = false;
    auto cur = msf.try_add_edge(edge.source_id, edge.target_id, edge.attr, success);
    if (cur)
    {
        auto [t1, t2] = proj(cur->attr);
        auto [ts, te] = proj(edge.attr);
        return std::pair{true, std::pair{cur->source_id,cur->target_id}};
    }
    return std::pair{success,std::nullopt};
}

template <typename VId>
auto connected_components(const std::vector<edge_descriptor<VId>> &edges)
{
    auto dsu = DSU<VId>{};
    for (auto &&e : edges)
    {
        dsu.add_edge(e.source_id, e.target_id);
    }
    std::vector<std::vector<VId>> temp(dsu.size());
    for (auto i = 0; i < dsu.size(); i++)
    {
        temp[dsu.find(i)].push_back(i);
    }
    std::vector<std::vector<VId>> res;
    for (auto &&cc : temp)
    {
        if (!cc.empty())
        {
            res.push_back(std::move(cc));
            std::ranges::sort(res.back());
        }
    }
    std::ranges::sort(res);
    return res;
}

template <typename VId>
auto size_tsf(const std::vector<edge_descriptor<VId>> &edges)
{
    size_t res = 0;
    auto dsu = DSU<VId>{};
    for (auto &&e : edges)
    {
        dsu.add_edge(e.source_id, e.target_id);
    }
    for (auto i = 0; i < dsu.size(); i++)
        if(dsu.find(i)!=i)
            res ++;
    return res;
}

template <typename VId, typename EA>
auto filter_edge(const std::vector<edge_descriptor<VId, EA>> &edges, const std::function<bool(EA)> &pred)
{
    auto res = edges | std::views::filter([&](auto &&e) { return pred(e.attr); });
    return std::vector<edge_descriptor<VId, EA>>{std::ranges::begin(res), std::ranges::end(res)};
}
